# Connected services — copy this file to .env.local and fill in real values.
# In the Avyrix live preview these are injected automatically.

# Your Supabase project (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Avyrix AI gateway — use your universal key to call AI models through Avyrix.
VITE_AVYRIX_API_URL=
VITE_AVYRIX_KEY=
